#!/usr/bin/python3
"""Tray-mode launcher for the Update Manager.

Delegates to the shared application entry point with --tray so only one
implementation exists.  The main window starts hidden; the tray icon
provides Show/Hide and Quit actions.
"""

import os
import sys

# Make the application package tree importable.
sys.path.insert(0, "/usr/lib/bodhi-update-manager")

# Remove the broken xapp GTK module from the environment if present.
_val = os.environ.get("GTK3_MODULES")
if _val:
    _parts = [m for m in _val.split(":") if m and m != "xapp-gtk3-module"]
    if _parts:
        os.environ["GTK3_MODULES"] = ":".join(_parts)
    else:
        os.environ.pop("GTK3_MODULES", None)

# Inject --tray so argparse in main() sees it.
sys.argv = [sys.argv[0], "--tray"]

from bodhi_update.app import main  # noqa: E402

main()
