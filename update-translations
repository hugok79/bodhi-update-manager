#!/usr/bin/env bash
#
# update-translations:
#    This script updates bodhi-update-manager's localization files.
#    Specifically, it uses the file po/POTFILES.in to determine
#    which source files should be scanned for translatable strings.
#    It then generates/updates the POT template using xgettext,
#    merges changes into existing .po files with msgmerge,
#    and creates new .po files for any languages listed in
#    po/LINGUAS that do not yet have one.
#
# Copyright 2026 ylee@bodhilinux.com
#
# This script is free software; you can redistribute it and/or
# modify it under the terms of the GNU General Public License as published
# by the Free Software Foundation; either version 3 of the License, or (at
# your option) any later version.
#
# This script is distributed in the hope that it will be useful,
# but WITHOUT ANY WARRANTY; without even the implied warranty of
# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE. See the GNU
# General Public License for more details.
#
# You should have received a copy of the GNU General Public License
# along with this script; if not, write to the Free Software
# Foundation, Inc., 59 Temple Place, Suite 330, Boston, MA 02111-1307 USA

set -euo pipefail

TMP_STUB=""          # path to generated C stub (set later, if needed)
TMP_STUB_LIST=""     # path to temp file-list containing the stub (set later)

cleanup() {
    [[ -n "$TMP_STUB" && -f "$TMP_STUB" ]]      && rm -f "$TMP_STUB"
    [[ -n "$TMP_STUB_LIST" && -f "$TMP_STUB_LIST" ]] && rm -f "$TMP_STUB_LIST"
}
trap cleanup EXIT

TRANSLATION_DIR="po"
POT_FILE="$TRANSLATION_DIR/bodhi-update-manager.pot"
FILE_LIST="$TRANSLATION_DIR/POTFILES.in"
VERSION=$(PYTHONPATH=src python3 -c 'from bodhi_update._version import __version__; print(__version__)')

check_command() {
    if ! command -v "$1" >/dev/null 2>&1; then
        echo "$1 could not be found."
        echo "You can install it with: sudo apt install gettext"
        exit 255
    fi
}

check_command xgettext
check_command msgmerge
check_command msginit

if [[ ! -f "$TRANSLATION_DIR/LINGUAS" ]]; then
    echo "Missing $TRANSLATION_DIR/LINGUAS"
    exit 1
fi

if [[ ! -f "$FILE_LIST" ]]; then
    echo "Missing $FILE_LIST"
    exit 1
fi

mapfile -t langs < <(grep -vE '^\s*($|#)' "$TRANSLATION_DIR/LINGUAS")

# ---------------------------------------------------------------------------
# Pre-process .policy files: extract <_description> / <_message> text into a
# temporary C stub so xgettext can pick them up without intltool.
# ---------------------------------------------------------------------------
POLICY_FILES=()
while IFS= read -r line; do
    [[ "$line" =~ ^[[:space:]]*(#|$) ]] && continue
    [[ "$line" == *.policy ]] && POLICY_FILES+=("$line")
done < "$FILE_LIST"

EXTRA_XGETTEXT_ARGS=()
if [[ ${#POLICY_FILES[@]} -gt 0 ]]; then
    TMP_STUB=$(mktemp /tmp/policy_stub_XXXXXX.c)
    TMP_STUB_LIST=$(mktemp /tmp/policy_stub_list_XXXXXX)

    for policy in "${POLICY_FILES[@]}"; do
        if [[ ! -f "$policy" ]]; then
            echo "Warning: $policy listed in POTFILES.in but not found — skipping."
            continue
        fi
        # Extract text inside <_description>...</_description> and <_message>...</_message>
        # Handles single-line elements only (polkit convention).
        grep -oP '(?<=<_description>)[^<]+(?=</_description>)|(?<=<_message>)[^<]+(?=</_message>)' "$policy" \
            | while IFS= read -r str; do
                  # Escape backslashes and double-quotes for C string literal
                  escaped=$(printf '%s' "$str" | sed 's/\\/\\\\/g; s/"/\\"/g')
                  printf '/* Translators: from %s */\n_("'"$escaped"'");\n' "$policy"
              done >> "$TMP_STUB"
    done

    if [[ -s "$TMP_STUB" ]]; then
        echo "$TMP_STUB" > "$TMP_STUB_LIST"
        EXTRA_XGETTEXT_ARGS=(--language=C --files-from="$TMP_STUB_LIST")
        echo "Extracted policy strings from: ${POLICY_FILES[*]}"
    fi
fi

# Build a POTFILES.in that excludes .policy files (they are handled above).
TMP_PY_LIST=$(mktemp /tmp/potfiles_py_XXXXXX)
trap 'cleanup; rm -f "$TMP_PY_LIST"' EXIT
grep -vE '\.policy$' "$FILE_LIST" > "$TMP_PY_LIST" || true

# ---------------------------------------------------------------------------
echo "Updating POT file"

# First pass: Python sources
xgettext \
  --language=Python \
  --from-code=UTF-8 \
  --keyword=_ \
  --keyword=N_ \
  --keyword=ngettext:1,2 \
  --package-name="bodhi-update-manager" \
  --package-version="$VERSION" \
  --msgid-bugs-address="https://github.com/flux-abyss/bodhi-update-manager/issues" \
  -o "$POT_FILE" \
  --files-from="$TMP_PY_LIST"

# Second pass: C stub with polkit strings (joined into an existing POT)
if [[ ${#EXTRA_XGETTEXT_ARGS[@]} -gt 0 ]]; then
    xgettext \
      --from-code=UTF-8 \
      --keyword=_ \
      --join-existing \
      -o "$POT_FILE" \
      "${EXTRA_XGETTEXT_ARGS[@]}"
fi

sed -i 's/^# Copyright (C) YEAR THE PACKAGE'\''S COPYRIGHT HOLDER/# Copyright (C) 2026 Bodhi Linux Team/' "$POT_FILE"

for lang in "${langs[@]}"; do
    po_file="$TRANSLATION_DIR/$lang.po"

    if [[ -f "$po_file" ]]; then
        echo "Updating $lang.po"
        msgmerge --update "$po_file" "$POT_FILE"
    else
        echo "Creating $lang.po"
        msginit \
            --input="$POT_FILE" \
            --locale="$lang" \
            --output-file="$po_file" \
            --no-translator
        # Set Language-Team
        sed -i "s/^\"Language-Team:.*\"/\"Language-Team: Bodhi Team\\\\n\"/" "$po_file"
    fi
done
