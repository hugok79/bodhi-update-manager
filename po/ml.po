#: src/bodhi_update/app.py:1661
msgid ""
"Enter your password in the terminal below. For security, nothing will appear "
"while typing."
msgstr ""
"താഴെയുള്ള ടെർമിനലിൽ നിങ്ങളുടെ പാസ്‌വേഡ് നൽകുക. സുരക്ഷയ്ക്കായി, ടൈപ്പ് ചെയ്യുമ്പോൾ ഒന്നും "
"പ്രദർശിപ്പിക്കില്ല."

#: src/bodhi_update/app.py:1665
msgid "Terminal auth in use — revealing VTE for password entry."
msgstr "ടെർമിനൽ ഓഥ് ഉപയോഗത്തിൽ — പാസ്‌വേഡ് നൽകൽക്കായി VTE പ്രദർശിപ്പിക്കുന്നു."

