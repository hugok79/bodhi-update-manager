#: src/bodhi_update/app.py:1630
msgid "Failed to start installation."
msgstr "ഇൻസ്റ്റാളേഷൻ ആരംഭിക്കുന്നതിൽ പരാജയപ്പെട്ടു."

#: src/bodhi_update/app.py:1633
#, python-format
