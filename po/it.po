#: src/bodhi_update/app.py:48
msgid ""
"Update Manager\n"
"\n"
"A lightweight graphical update manager for Debian based distros."
msgstr ""
"Update Manager\n"
"\n"
"Un manager di aggiornamenti grafico e leggero per distribuzioni basate su "
"Debian."

